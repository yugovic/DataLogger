{
  "name": "car-setup-logger",
  "version": "1.0.0",
  "description": "車両セットアップ記録システム - VELOCITY LOGGER",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore --project velocity-logger-rules-test \"vitest run --config vite.rules.config.ts\"",
    "test:mobile": "playwright test tests/mobile-responsive.spec.ts",
    "i18n:pseudo-locale": "playwright test tests/pseudo-locale.spec.ts",
    "test:watch": "vitest",
    "i18n:check-hardcoded": "node scripts/check-hardcoded-japanese.mjs",
    "i18n:check-keys": "vitest run src/i18n/i18n.test.ts src/i18n/i18nIntegrity.test.ts",
    "i18n:check": "npm run i18n:check-hardcoded && npm run i18n:check-keys"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.12.0",
    "echarts": "^6.1.0",
    "firebase": "^11.10.0",
    "i18next": "^26.3.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.10",
    "react-router-dom": "^7.6.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.24.0",
    "globals": "^17.6.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.8"
  }
}
