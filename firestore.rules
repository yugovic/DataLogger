rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 共有相互性（Give-to-Get）の判定ヘルパー ──────────────────────────
    // 事業要件: 「自分のデータを共有した人だけが、他人の共有データを閲覧できる」
    // 相互性を UI の建前ではなく **このルールで強制** する（BUSINESS_PLAN Phase 0c）。
    //
    // 認可の根拠は users/{uid}.sharingActive のような自己申告フラグに置かない。
    // sharingEntitlements/{uid}.setupId が、本人所有かつ現在 shared のセットアップを
    // 指していることをルール内で毎回検証する。クライアントが entitlement を直接
    // 書いても、実際の共有データが無ければ閲覧権限は成立しない。
    function requesterSharingActive() {
      return request.auth != null
        && exists(/databases/$(database)/documents/sharingEntitlements/$(request.auth.uid))
        && get(/databases/$(database)/documents/sharingEntitlements/$(request.auth.uid)).data.setupId is string
        && exists(/databases/$(database)/documents/setups/$(get(/databases/$(database)/documents/sharingEntitlements/$(request.auth.uid)).data.setupId))
        && get(/databases/$(database)/documents/setups/$(get(/databases/$(database)/documents/sharingEntitlements/$(request.auth.uid)).data.setupId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/setups/$(get(/databases/$(database)/documents/sharingEntitlements/$(request.auth.uid)).data.setupId)).data.visibility == 'shared';
    }

    function validSharingEntitlement(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['setupId', 'updatedAt'])
        && request.resource.data.keys().hasOnly(['setupId', 'updatedAt'])
        && request.resource.data.setupId is string
        && request.resource.data.updatedAt == request.time
        && exists(/databases/$(database)/documents/setups/$(request.resource.data.setupId))
        && get(/databases/$(database)/documents/setups/$(request.resource.data.setupId)).data.userId == userId
        && get(/databases/$(database)/documents/setups/$(request.resource.data.setupId)).data.visibility == 'shared';
    }

    // visibility は 'private' | 'shared' のいずれかに限定する。
    // 不正値（例: 'public'）の混入を create/update 時に防ぎ、共有判定を堅牢に保つ。
    // 旧データ互換: フィールド欠落（未設定）は private 扱いとして許容する。
    function validVisibility(data) {
      return !('visibility' in data.keys())
        || data.visibility == 'private'
        || data.visibility == 'shared';
    }

    function validTireSet(data) {
      return data.code is string && data.code.size() > 0 && data.code.size() <= 40
        && data.manufacturer is string && data.manufacturer.size() > 0 && data.manufacturer.size() <= 60
        && data.productName is string && data.productName.size() > 0 && data.productName.size() <= 80
        && data.compound is string && data.compound.size() <= 40
        && data.frontSize is string && data.frontSize.size() <= 40
        && data.rearSize is string && data.rearSize.size() <= 40
        && data.notes is string && data.notes.size() <= 500
        && data.initialDistanceKm is number && data.initialDistanceKm >= 0 && data.initialDistanceKm <= 100000
        && data.initialLaps is int && data.initialLaps >= 0 && data.initialLaps <= 100000
        && data.initialHeatCycles is int && data.initialHeatCycles >= 0 && data.initialHeatCycles <= 10000
        && (data.status == 'active' || data.status == 'stored' || data.status == 'retired');
    }

    // 公開共有リンクは未認証閲覧を許可するため、作成時に表示用summaryの形を固定する。
    // driver / userId / anonymized / セットアップ数値詳細はsummaryに入れない。
    function validPublicVehicleProfileSnapshot(profile) {
      return profile == null || (
        profile is map
        && profile.keys().hasOnly(['modifications', 'tireClass', 'powerPs', 'weightKg', 'modLevel'])
        && profile.modifications is list
        && (profile.tireClass == null || profile.tireClass is string)
        && (profile.powerPs == null || profile.powerPs is number)
        && (profile.weightKg == null || profile.weightKg is number)
        && profile.modLevel is string
      );
    }

    function validPublicShareSummary(summary) {
      return summary is map
        && summary.keys().hasAll([
          'circuit',
          'carModel',
          'bestLap',
          'sessionDate',
          'hasLoggerEvidence',
          'vehicleProfileSnapshot'
        ])
        && summary.keys().hasOnly([
          'circuit',
          'carModel',
          'bestLap',
          'sessionDate',
          'hasLoggerEvidence',
          'vehicleProfileSnapshot'
        ])
        && summary.circuit is string
        && summary.carModel is string
        && (summary.bestLap == null || summary.bestLap is string)
        && summary.sessionDate is timestamp
        && summary.hasLoggerEvidence is bool
        && validPublicVehicleProfileSnapshot(summary.vehicleProfileSnapshot);
    }

    function validPublicShareCreate(shareId) {
      return shareId.matches('^[A-Za-z0-9]{12,}$')
        && request.resource.data.keys().hasAll(['ownerId', 'setupId', 'createdAt', 'summary'])
        && request.resource.data.keys().hasOnly(['ownerId', 'setupId', 'createdAt', 'summary'])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.setupId is string
        && request.resource.data.createdAt == request.time
        && exists(/databases/$(database)/documents/setups/$(request.resource.data.setupId))
        && get(/databases/$(database)/documents/setups/$(request.resource.data.setupId)).data.userId == request.auth.uid
        && validPublicShareSummary(request.resource.data.summary);
    }

    // セットアップ（トップレベル）
    match /setups/{setupId} {
      // 作成時: リクエストデータの userId が自分で、visibility が正当値であること
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        validVisibility(request.resource.data);

      // 更新時: オーナーのみ、かつ userId を改変せず、visibility が正当値であること
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        validVisibility(request.resource.data);

      // 削除: オーナーのみ
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;

      // 読み取り: オーナーは常に可。
      // 他人のドキュメントは「visibility == 'shared'」かつ
      // 「リクエストユーザーが sharingActive == true（＝自分も共有している）」場合のみ可。
      // これにより未共有ユーザーは他人の shared データを一切読めない（相互性の強制）。
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (resource.data.visibility == 'shared' && requesterSharingActive())
      );
    }

    // 公開ランディングページ用の匿名サマリー。read は未認証を含め誰でも可。
    match /publicShares/{shareId} {
      allow read: if true;
      allow create: if request.auth != null && validPublicShareCreate(shareId);
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow update: if false;
    }

    // 比較用テレメトリトレース（ラップ単位の間引きデータ）
    match /telemetryTraces/{traceId} {
      // 作成: オーナーのみ。Phase B1 では private/shared のみ許可する。
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid &&
        (
          request.resource.data.visibility == 'private' ||
          request.resource.data.visibility == 'shared'
        );

      // 更新/削除: オーナーのみ。ownerId は改変不可。
      allow update: if request.auth != null &&
        resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerId == request.auth.uid &&
        (
          request.resource.data.visibility == 'private' ||
          request.resource.data.visibility == 'shared'
        );
      allow delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;

      // 読み取り: オーナーは常に可。shared は既存の Give-to-Get 条件と同じ。
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        (resource.data.visibility == 'shared' && requesterSharingActive())
      );
    }

    // Give-to-Get の権利証明。本人が所有する shared セットアップだけを参照できる。
    // read/delete は本人のみ。create/update は validSharingEntitlement で実体を検証する。
    match /sharingEntitlements/{userId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if validSharingEntitlement(userId);
    }

    // テスト用コレクション
    match /test/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ユーザードキュメント（プロフィール）
    // write は本人のみ（sharingActive を他人が書き換えられないことが相互性の前提）。
    // read も本人のみで足りる: 他人の sharingActive を参照する箇所は上の get() が
    // ルール権限で評価するため、公開 read は不要（最小権限の原則）。
    // 画面表示用に本人の read が必要なので本人 read は許可する。
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ユーザー配下のレガシー setups サブコレクション（現行どおり本人のみ）
      match /setups/{setupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 車両データ（現行どおりオーナーのみ）
    match /vehicles/{vehicleId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // ユーザー所有の物理タイヤセット。走行実績は setups を原本として集計する。
    match /tireSets/{tireSetId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId &&
        validTireSet(request.resource.data);
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId &&
        validTireSet(request.resource.data);
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
